---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import SocialShares from '@components/SocialShares.astro'
import { Badge, Heading } from 'accessible-astro-components'
import { getCollection, render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'
import YouTubePlayer from '@components/YouTubePlayer.astro'

function getYoutubeEmbedUrl(url: string): string {
  const match = url.match(/(?:v=|youtu\.be\/)([^&\n?#]+)/)
  return match ? `https://www.youtube.com/embed/${match[1]}` : ''
}

function getYoutubeThumbnail(url: string): string {
  const match = url.match(/(?:v=|youtu\.be\/)([^&\n?#]+)/)
  return match ? `https://img.youtube.com/vi/${match[1]}/hqdefault.jpg` : '/placeholder.png'
}

export async function getStaticPaths() {
  const episodes = await getCollection('episodes')
  return episodes.map((episode) => ({
    params: { episode: episode.id },
    props: { episode },
  }))
}

interface Props {
  episode: CollectionEntry<'episodes'>
}

const { episode } = Astro.props
const { Content } = await render(episode)
const embedUrl = getYoutubeEmbedUrl(episode.data.youtubeUrl)
const thumbnail = getYoutubeThumbnail(episode.data.youtubeUrl)

const author = {
  name: episode.data.guestName ?? episode.data.author,
  image: thumbnail,
  bio: episode.data.guestName ? `Guest on Episode ${episode.data.episodeNumber ?? ''}` : 'Host',
}

const formattedDate = episode.data.publishDate
  ? new Intl.DateTimeFormat('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).format(
      episode.data.publishDate,
    )
  : null
---

<DefaultLayout title={episode.data.title} description={episode.data.description} url={`/episodes/${episode.id}`}>
  <PageHeader title={episode.data.title} subtitle={episode.data.description} author={author} bgType="bordered" />

  <section class="my-12">
    <div class="narrow container">
      <!-- Meta -->
      <div class="mb-6 flex flex-wrap items-center gap-3">
        {episode.data.episodeNumber && <Badge>Episode {episode.data.episodeNumber}</Badge>}
        {episode.data.tags.map((tag) => <Badge>{tag}</Badge>)}
        {formattedDate && <span class="text-sm text-neutral-500">{formattedDate}</span>}
      </div>

      <!-- YouTube Embed -->
      {
        embedUrl && (
          <div class="video-wrapper mb-10">
            {/* <iframe
              src={embedUrl}
              title={`YouTube video: ${episode.data.title}`}
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen/> */}

            <YouTubePlayer url={episode.data.youtubeUrl} title={episode.data.title} />
          </div>
        )
      }

      <!-- Show Notes / Content -->
      <div class="space-content">
        <Content />
      </div>
    </div>
  </section>

  <section class="my-12">
    <div class="narrow container">
      <Heading level="h2">Share this episode</Heading>
      <p>Found this episode helpful? Share it with your community.</p>
      <SocialShares />
    </div>
  </section>
</DefaultLayout>

<style lang="scss" is:global>
  .narrow {
    margin-inline: auto;
    max-width: 65ch;
  }

  .video-wrapper {
    position: relative;
    border-radius: var(--radius-large);
    padding-bottom: 56.25%; /* 16:9 */
    height: 0;
    overflow: hidden;

    iframe {
      position: absolute;
      top: 0;
      left: 0;
      border: 0;
      width: 100%;
      height: 100%;
    }
  }
</style>
