---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Heading, Notification } from 'accessible-astro-components'
import { getCollection } from 'astro:content'

const episodes = await getCollection('episodes')
const sortedEpisodes = episodes.sort((a, b) => (a.data.episodeNumber ?? 0) - (b.data.episodeNumber ?? 0))

const staticPages = [
  {
    title: 'Home',
    url: '/',
    description: 'Welcome to South Asian Women in Rare.',
  },
  {
    title: 'Episodes',
    url: '/episodes',
    description: 'Browse all podcast episodes featuring South Asian women sharing their rare disease experiences.',
  },
  {
    title: 'Blog',
    url: '/blog',
    description: 'Articles and insights about rare disease, advocacy, and community.',
  },
  {
    title: 'Contact',
    url: '/contact',
    description: 'Get in touch — share your story or connect with us.',
  },
  {
    title: 'Thank you',
    url: '/thank-you',
    description: 'Confirmation page after form submission.',
  },
]
---

<DefaultLayout title="Sitemap" description="Complete sitemap for South Asian Women in Rare — all pages and episodes.">
  <PageHeader
    title="Sitemap"
    subtitle="An overview of all pages and episodes available on our website."
    bgType="gradient"
  />

  <section class="my-16">
    <div class="container space-y-12">
      <!-- Main Pages -->
      <div>
        <Heading level="h2" class="mb-6">Main pages</Heading>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            staticPages.map((page) => (
              <article>
                <Heading level="h3" size="h6" class="mb-3">
                  <a href={page.url}>{page.title}</a>
                </Heading>
                <p class="mb-3">{page.description}</p>
                <p class="text-xs">
                  URL:{' '}
                  <code class="rounded bg-neutral-100 px-1 py-0.5 text-xs text-neutral-500 dark:bg-neutral-800 dark:text-neutral-500">
                    {page.url}
                  </code>
                </p>
              </article>
            ))
          }
        </div>
      </div>

      <!-- Episodes -->
      <div>
        <Heading level="h2" class="mb-2">Episodes</Heading>
        <p class="mb-6">All episodes of South Asian Women in Rare.</p>
        <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
          {
            sortedEpisodes.map((episode) => (
              <article>
                <Heading level="h3" size="h6" class="mb-3">
                  <a href={`/episodes/${episode.id}`}>
                    {episode.data.episodeNumber ? `Ep. ${episode.data.episodeNumber}: ` : ''}
                    {episode.data.title}
                  </a>
                </Heading>
                <p class="mb-3">{episode.data.description}</p>
                <div class="text-xs">
                  {episode.data.guestName && (
                    <p class="mb-1">
                      Guest: <span class="font-medium">{episode.data.guestName}</span>
                    </p>
                  )}
                  <p>
                    URL:{' '}
                    <code class="rounded bg-neutral-100 px-1 py-0.5 text-xs text-neutral-500 dark:bg-neutral-800 dark:text-neutral-500">
                      /episodes/{episode.id}
                    </code>
                  </p>
                </div>
              </article>
            ))
          }
        </div>
      </div>

      <Notification type="info" variant="accent">
        <div class="space-content">
          <Heading level="h2" size="h6" class="mb-4">Technical sitemap information</Heading>
          <ul>
            <li>
              <strong>XML Sitemap:</strong> Auto-generated at <code>/sitemap.xml</code> for search engines.
            </li>
            <li>
              <strong>Generated by:</strong> @astrojs/sitemap in astro.config.mjs
            </li>
            <li>
              <strong>Last updated:</strong> Automatically on each build
            </li>
          </ul>
        </div>
      </Notification>
    </div>
  </section>
</DefaultLayout>

<style>
  article {
    border: 1px solid var(--border-color-subtle);
    border-radius: var(--radius-large);
    background-color: var(--background-color);
    padding: 1rem;
  }
</style>
