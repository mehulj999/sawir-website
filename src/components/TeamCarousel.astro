import { getCollection } from 'astro:content'
import { Card } from 'accessible-astro-components'
// import avatar from '@assets/img/avatar.png'
const teamEntries = await getCollection('team')
const team = teamEntries.sort((a, b) => a.data.order - b.data.order)
---

<section class="my-64" aria-labelledby="team-heading">
  <div class="container">
    <div class="mb-8">
      <h2 id="team-heading" class="text-3xl font-bold">Meet the team</h2>
      <p class="mt-2 text-xl">The people behind South Asian Women in Rare.</p>
    </div>

    <div class="carousel-wrapper">
      <!-- <div class="carousel" id="team-carousel" role="region" aria-label="Team members">
        {
          team.map((member) => (
            <article class="carousel-card" aria-label={`${member.data.name}, ${member.data.role}`}>
              {/* FIX: Use member.data.color and member.data.initials */}
              <div class={`avatar avatar--${member.data.color}`} aria-hidden="true">
                {member.data.initials}
              </div>

              <h3 class="mt-4 text-lg font-semibold">{member.data.name}</h3>
              <p class="role">{member.data.role}</p>
              <p class="bio">{member.data.bio}</p>
            </article>
          ))
        }
      </div> -->

      <div class="carousel" id="team-carousel" role="region" aria-label="Team members">
        {
          team.map((member) => (
            <Card
                img={member.data.img_url}
                width={400} height={400}
                url="/blog/post"
                title={member.data.name}
                class="carousel-card">
              <p class="role">{member.data.role}</p>
              <p class="bio">{member.data.bio}</p>
            </Card>

            // <article class="carousel-card" aria-label={`${member.data.name}, ${member.data.role}`}>
            //   {/* FIX: Use member.data.color and member.data.initials */}
            //   <div class={`avatar avatar--${member.data.color}`} aria-hidden="true">
            //     {member.data.initials}
            //   </div>

            //   <h3 class="mt-4 text-lg font-semibold">{member.data.name}</h3>
            //   <p class="role">{member.data.role}</p>
            //   <p class="bio">{member.data.bio}</p>
            // </article>
          ))
        }
      </div>

      <div class="carousel-controls" aria-label="Carousel navigation">
        <button id="prev-btn" class="carousel-btn" type="button"> ← </button>
        <div class="carousel-dots" id="carousel-dots">
          {team.map((_, i) => <span class={`dot${i === 0 ? ' dot--active' : ''}`} data-index={i} />)}
        </div>
        <button id="next-btn" class="carousel-btn" type="button"> → </button>
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const carousel = document.getElementById('team-carousel')
    const prevBtn = document.getElementById('prev-btn')
    const nextBtn = document.getElementById('next-btn')
    const dots = document.querySelectorAll('.dot')

    if (!carousel || !prevBtn || !nextBtn) return

    const cards = carousel.querySelectorAll('.carousel-card')
    const total = cards.length

    let current = 0

    function getVisibleCount() {
      const w = window.innerWidth
      if (w >= 1024) return 3
      if (w >= 640) return 2
      return 1
    }

    function updateDots(index) {
      dots.forEach((d, i) => {
        d.classList.toggle('dot--active', i === index)
      })
    }

    function scrollToCard(index) {
      const visible = getVisibleCount()
      const max = Math.max(0, total - visible)

      current = Math.max(0, Math.min(index, max))

      cards[current]?.scrollIntoView({
        behavior: 'smooth',
        inline: 'start',
        block: 'nearest',
      })

      updateDots(current)

      prevBtn.disabled = current === 0
      nextBtn.disabled = current >= max
    }

    prevBtn.addEventListener('click', () => scrollToCard(current - 1))
    nextBtn.addEventListener('click', () => scrollToCard(current + 1))

    dots.forEach((dot) => {
      dot.addEventListener('click', () => {
        const idx = parseInt(dot.dataset.index || '0', 10)
        scrollToCard(idx)
      })
    })

    window.addEventListener('resize', () => scrollToCard(current))

    scrollToCard(0)
  })
</script>

<style>
  .carousel-wrapper {
    position: relative;
  }

  .carousel {
    display: flex;
    gap: 1.5rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 0.5rem;
  }

  .carousel::-webkit-scrollbar {
    display: none;
  }

  .carousel-card {
    flex: 0 0 calc((100% - 3rem) / 3);
    transition:
      transform 0.2s ease,
      box-shadow 0.2s ease;
    border: 1px solid var(--border-color-subtle);
    border-radius: var(--radius-large);
    background-color: var(--background-color);
    padding: 1.5rem;
    scroll-snap-align: start;
  }

  .carousel-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
  }

  @media (max-width: 1023px) {
    .carousel-card {
      flex: 0 0 calc((100% - 1.5rem) / 2);
    }
  }

  @media (max-width: 639px) {
    .carousel-card {
      flex: 0 0 100%;
    }
  }

  .avatar {
    display: flex;
    justify-content: center;
    align-items: center;
    border-radius: 50%;
    width: 3.5rem;
    height: 3.5rem;
    color: white;
    font-weight: 700;
    font-size: 0.875rem;
  }

  .avatar--primary {
    background-color: var(--color-primary);
  }

  .avatar--secondary {
    background-color: var(--color-secondary);
  }

  .role {
    margin-top: 0.125rem;
    margin-bottom: 0.75rem;
    color: var(--color-primary);
    font-weight: 500;
    font-size: 0.875rem;
  }

  .bio {
    opacity: 0.8;
    color: var(--text-color-muted, currentColor);
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .carousel-controls {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .carousel-btn {
    display: flex;
    justify-content: center;
    align-items: center;
    transition:
      border-color 0.15s,
      background-color 0.15s;
    cursor: pointer;
    border: 2px solid var(--border-color-subtle);
    border-radius: 50%;
    background: var(--background-color);
    width: 2.5rem;
    height: 2.5rem;
    font-size: 1rem;
  }

  .carousel-btn:hover:not(:disabled) {
    border-color: var(--color-primary);
    background-color: var(--color-primary);
    color: white;
  }

  .carousel-btn:disabled {
    opacity: 0.35;
    cursor: not-allowed;
  }

  .carousel-btn:focus-visible {
    outline: 3px solid var(--color-primary);
    outline-offset: 2px;
  }

  .carousel-dots {
    display: flex;
    gap: 0.5rem;
  }

  .dot {
    transition:
      background-color 0.15s,
      transform 0.15s;
    cursor: pointer;
    border-radius: 50%;
    background-color: var(--border-color-subtle);
    width: 0.5rem;
    height: 0.5rem;
  }

  .dot--active {
    transform: scale(1.3);
    background-color: var(--color-primary);
  }
</style>
