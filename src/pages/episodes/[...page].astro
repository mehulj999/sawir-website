---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Badge, Card, Heading, Link, Pagination } from 'accessible-astro-components'
import { getCollection } from 'astro:content'
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { slugify } from '@utils/slugify'

function getYoutubeThumbnail(url: string): string {
  const match = url.match(/(?:v=|youtu\.be\/)([^&\n?#]+)/)
  return match ? `https://img.youtube.com/vi/${match[1]}/hqdefault.jpg` : '/placeholder.png'
}

export const getStaticPaths = (async ({ paginate }) => {
  const episodes = await getCollection('episodes')

  const sortedEpisodes = episodes.sort((a, b) => {
    const numA = a.data.episodeNumber ?? 0
    const numB = b.data.episodeNumber ?? 0
    return numB - numA
  })

  const allTags = sortedEpisodes.flatMap((ep) => ep.data.tags)
  const uniqueTagLabels = [...new Set(allTags)].sort((a, b) => a.localeCompare(b))
  const uniqueTags = uniqueTagLabels.map((label) => ({
    label,
    slug: slugify(label),
  }))

  return paginate(sortedEpisodes, {
    pageSize: 6,
    props: { uniqueTags },
  })
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'episodes'>>
  uniqueTags: { label: string; slug: string }[]
}

const { page, uniqueTags } = Astro.props
---

<DefaultLayout
  title="Episodes"
  description="Listen to South Asian Women in Rare — stories, journeys, and insights from women navigating rare disease."
>
  <PageHeader
    title="Episodes"
    subtitle="Stories, journeys, and insights from South Asian women living with or supporting someone with a rare disease."
    bgType="bordered"
  />
  <section class="my-12">
    <div class="container">
      {
        uniqueTags.length > 0 && (
          <>
            <Heading level="h2" size="h5" class="mb-2">
              Filter by topic
            </Heading>
            <div class="flex flex-wrap gap-4">
              {uniqueTags.map((tag) => (
                <Link href={`/episodes/tag/${tag.slug}`}>{tag.label}</Link>
              ))}
            </div>
          </>
        )
      }
      <p class="mt-8 text-sm">
        <em>Episode {page.start + 1} through {page.end + 1} of {page.total} total episodes</em>
      </p>
      <ul class="mt-3 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          page.data.map((episode) => (
            <li>
              <Card
                imageSrc={getYoutubeThumbnail(episode.data.youtubeUrl)}
                imageAlt={`Thumbnail for ${episode.data.title}`}
                url={`/episodes/${episode.id}`}
                title={episode.data.title}
                headingLevel="h2"
                footer={`Guest: ${episode.data.guestName ?? episode.data.author}`}
                fullHeight={true}
              >
                <span slot="meta">
                  {episode.data.episodeNumber && <Badge>Ep. {episode.data.episodeNumber}</Badge>}
                  {episode.data.tags.map((tag) => (
                    <Badge>{tag}</Badge>
                  ))}
                </span>
                {episode.data.description}
              </Card>
            </li>
          ))
        }
      </ul>
      {
        page.lastPage > 1 && (
          <div class="mt-12 grid place-content-center">
            <Pagination
              firstPage={page.url.prev ? '/episodes' : null}
              previousPage={page.url.prev ?? null}
              nextPage={page.url.next ?? null}
              lastPage={page.url.next ? `/episodes/${page.lastPage}` : null}
              currentPage={`${page.currentPage}`}
              totalPages={`${page.lastPage}`}
              ariaLabel="Episodes pagination"
            />
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>
