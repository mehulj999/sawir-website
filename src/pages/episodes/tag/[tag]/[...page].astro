---
import DefaultLayout from '@layouts/DefaultLayout.astro'
import PageHeader from '@components/PageHeader.astro'
import { Badge, Card, Heading, Link, Pagination } from 'accessible-astro-components'
import { getCollection } from 'astro:content'
import type { GetStaticPaths, Page } from 'astro'
import type { CollectionEntry } from 'astro:content'
import { slugify } from '@utils/slugify'

function getYoutubeThumbnail(url: string): string {
  const match = url.match(/(?:v=|youtu\.be\/)([^&\n?#]+)/)
  return match ? `https://img.youtube.com/vi/${match[1]}/hqdefault.jpg` : '/placeholder.png'
}

export const getStaticPaths = (async ({ paginate }) => {
  const episodes = await getCollection('episodes')

  const allTags = episodes.flatMap((ep) => ep.data.tags)
  const uniqueTagLabels = [...new Set(allTags)].sort((a, b) => a.localeCompare(b))
  const uniqueTags = uniqueTagLabels.map((label) => ({
    label,
    slug: slugify(label),
  }))

  const allPaginatedPages = []

  for (const tag of uniqueTags) {
    const filtered = episodes.filter((ep) => ep.data.tags.map((t) => slugify(t)).includes(tag.slug))

    const pages = paginate(filtered, {
      pageSize: 6,
      params: { tag: tag.slug },
      props: { currentTag: tag, uniqueTags },
    })

    allPaginatedPages.push(...pages)
  }

  return allPaginatedPages
}) satisfies GetStaticPaths

interface Props {
  page: Page<CollectionEntry<'episodes'>>
  currentTag: { label: string; slug: string }
  uniqueTags: { label: string; slug: string }[]
}

const { page, currentTag, uniqueTags } = Astro.props
---

<DefaultLayout
  title={`Episodes — ${currentTag.label}`}
  description={`Episodes tagged with "${currentTag.label}" from South Asian Women in Rare.`}
>
  <PageHeader
    title={`Topic: ${currentTag.label}`}
    subtitle={`${page.total} episode${page.total !== 1 ? 's' : ''} tagged with "${currentTag.label}". <a href="/episodes">View all episodes</a>`}
    bgType="bordered"
    customBreadcrumbLabels={{ [currentTag.slug]: currentTag.label }}
    joinLastBreadcrumb={true}
  />
  <section class="my-12">
    <div class="container">
      <Heading level="h2" size="h5" class="mb-2">All topics</Heading>
      <div class="flex flex-wrap gap-4">
        <Link href="/episodes">All episodes</Link>
        {
          uniqueTags.map((tag) => {
            const isCurrent = tag.slug === currentTag.slug
            return isCurrent ? (
              <Link href={`/episodes/tag/${tag.slug}`} disabled class="disabled">
                {tag.label}
              </Link>
            ) : (
              <Link href={`/episodes/tag/${tag.slug}`}>{tag.label}</Link>
            )
          })
        }
      </div>

      <p class="mt-8 text-sm">
        <em>
          Episode {page.start + 1} through {page.end + 1} of {page.total} total episodes tagged with "{
            currentTag.label
          }"
        </em>
      </p>
      <ul class="mt-3 grid grid-cols-1 gap-6 md:grid-cols-2 lg:grid-cols-3">
        {
          page.data.map((episode) => (
            <li>
              <Card
                imageSrc={getYoutubeThumbnail(episode.data.youtubeUrl)}
                imageAlt={`Thumbnail for ${episode.data.title}`}
                url={`/episodes/${episode.id}`}
                title={episode.data.title}
                headingLevel="h2"
                footer={`Guest: ${episode.data.guestName ?? episode.data.author}`}
                fullHeight={true}
              >
                <span slot="meta">
                  {episode.data.episodeNumber && <Badge>Ep. {episode.data.episodeNumber}</Badge>}
                  {episode.data.tags.map((tag) => {
                    const isCurrent = tag === currentTag.label
                    return isCurrent ? <Badge class="bg-primary text-white">{tag}</Badge> : <Badge>{tag}</Badge>
                  })}
                </span>
                {episode.data.description}
              </Card>
            </li>
          ))
        }
      </ul>

      {
        page.lastPage > 1 && (
          <div class="mt-12 grid place-content-center">
            <Pagination
              firstPage={page.url.prev ? `/episodes/tag/${currentTag.slug}` : null}
              previousPage={page.url.prev ?? null}
              nextPage={page.url.next ?? null}
              lastPage={page.url.next ? `/episodes/tag/${currentTag.slug}/${page.lastPage}` : null}
              currentPage={`${page.currentPage}`}
              totalPages={`${page.lastPage}`}
              ariaLabel={`${currentTag.label} episodes pagination`}
            />
          </div>
        )
      }
    </div>
  </section>
</DefaultLayout>
